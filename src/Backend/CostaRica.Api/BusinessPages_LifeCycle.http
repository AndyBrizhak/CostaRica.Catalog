@base_url = http://localhost:5046
@contentType = application/json

############################################################
### ЭТАП 1: ПОДГОТОВКА (SUPER ADMIN)
############################################################

# 1.1 Вход как Super Admin
# @name loginAdmin
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "password": "ComplexPassword123!"
}

###
@adminToken = {{loginAdmin.response.body.$.token}}

# 1.2 Создание инфраструктуры (Провинция, Категория)
# @name createInfra
POST {{base_url}}/api/provinces
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}

{ "name": "Testing Region", "slug": "test-region" }

###
@provinceId = {{createInfra.response.body.$.id}}

# @name createCat
POST {{base_url}}/api/google-categories
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}

{ "gcid": "test_cat", "nameEn": "Test Category", "nameEs": "Cat de prueba" }

###
@catId = {{createCat.response.body.$.id}}


############################################################
### ЭТАП 2: ПРАВА ДОСТУПА (MANAGER)
############################################################

# 2.1 Регистрация и назначение роли Manager
# @name regManager
POST {{base_url}}/api/auth/register
Content-Type: {{contentType}}

{ "email": "manager-test@example.com", "password": "Password123!", "userName": "ManagerTester" }

###
@managerId = {{regManager.response.body.$.id}}

# Назначаем роль от имени Админа
PUT {{base_url}}/api/admin/users/{{managerId}}/roles
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}

[ "Manager" ]

###

# 2.2 Вход под Менеджером
# @name loginManager
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{ "email": "manager-test@example.com", "password": "Password123!" }

###
@managerToken = {{loginManager.response.body.$.token}}


############################################################
### ЭТАП 3: ТЕСТ ДУБЛИКАТОВ И СЛАГОВ (409 CONFLICT)
############################################################

# 3.1 Создание страницы (Оригинал)
# @name createOriginal
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{managerToken}}
Content-Type: {{contentType}}

{
  "name": "Unique Business Name",
  "slug": "unique-slug",
  "isPublished": true,
  "languageCode": "en",
  "provinceId": "{{provinceId}}",
  "primaryCategoryId": "{{catId}}",
  "location": { "latitude": 9.3, "longitude": 123.3 }
}

###
@pageId = {{createOriginal.response.body.$.id}}

# 3.2 ТЕСТ КОНФЛИКТА: Попытка создать с ТЕМ ЖЕ слагом
# Ожидается: 409 Conflict
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{managerToken}}
Content-Type: {{contentType}}

{
  "name": "Another Name But Same Slug",
  "slug": "unique-slug",
  "provinceId": "{{provinceId}}",
  "location": { "latitude": 10.0, "longitude": 120.0 }
}

###

# 3.3 ТЕСТ ИСТОРИИ: Смена слага и проверка OldSlugs
# Мы меняем "unique-slug" на "new-cool-slug"
PUT {{base_url}}/api/admin/business-pages/{{pageId}}
Authorization: Bearer {{managerToken}}
Content-Type: {{contentType}}

{
  "name": "Unique Business Name",
  "slug": "new-cool-slug",
  "isPublished": true,
  "provinceId": "{{provinceId}}",
  "location": { "latitude": 9.3, "longitude": 123.3 }
}

###
# Проверка: В ответе поле "oldSlugs" должно содержать ["unique-slug"]
GET {{base_url}}/api/admin/business-pages/{{pageId}}
Authorization: Bearer {{managerToken}}


############################################################
### ЭТАП 4: ТЕСТ УРОВНЕЙ ДОСТУПА (RBAC)
############################################################

# 4.1 ТЕСТ: Менеджер пытается УДАЛИТЬ страницу
# Ожидается: 403 Forbidden (т.к. DELETE требует AdminFullAccess)
DELETE {{base_url}}/api/admin/business-pages/{{pageId}}
Authorization: Bearer {{managerToken}}

###

# 4.2 ТЕСТ: Админ успешно УДАЛЯЕТ страницу
# Ожидается: 204 No Content
DELETE {{base_url}}/api/admin/business-pages/{{pageId}}
Authorization: Bearer {{adminToken}}


############################################################
### ЭТАП 5: ОЧИСТКА
############################################################

DELETE {{base_url}}/api/admin/users/{{managerId}}
Authorization: Bearer {{adminToken}}

###
DELETE {{base_url}}/api/google-categories/{{catId}}
Authorization: Bearer {{adminToken}}

###
DELETE {{base_url}}/api/provinces/{{provinceId}}
Authorization: Bearer {{adminToken}}