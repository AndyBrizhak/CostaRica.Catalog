@base_url = http://localhost:5046
@contentType = application/json

### 1. Логин SuperAdmin
# @name loginSuperAdmin
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "password": "ComplexPassword123!"
}

###

# ПЕРЕМЕННЫЕ ВЫНОСИМ СТРОГО ПОСЛЕ РАЗДЕЛИТЕЛЯ ###
@superAdminToken = {{loginSuperAdmin.response.body.$.token}}

### 2. Логин Менеджера
# @name loginManager
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "manager-tags@example.com",
  "password": "Password123!"
}

###

@managerToken = {{loginManager.response.body.$.token}}

### 3. Массовый импорт (Тестовый)
# @name bulkImport
POST {{base_url}}/api/google-categories/bulk
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

[
  { "gcid": "bakery-test", "nameEn": "Bakery", "nameEs": "Panadería" },
  { "gcid": "bar-test", "nameEn": "Bar", "nameEs": "Bar" }
]

### 4. Получение списка
# @name getList
GET {{base_url}}/api/google-categories?searchTerm=test
Authorization: Bearer {{superAdminToken}}

### 5. Удаление (Ручная вставка ID)
# Выполни запрос выше, скопируй id и подставь его сюда
DELETE {{base_url}}/api/google-categories/ВСТАВЬ_ID_ЗДЕСЬ
Authorization: Bearer {{superAdminToken}}

### 6. Проверка доступа Менеджера (Только чтение)
GET {{base_url}}/api/google-categories
Authorization: Bearer {{managerToken}}