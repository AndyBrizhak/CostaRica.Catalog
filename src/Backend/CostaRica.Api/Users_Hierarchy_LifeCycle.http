@base_url = http://localhost:5046
@contentType = application/json

# Данные начального администратора
@initialAdminEmail = admin@example.com
@initialAdminPassword = ComplexPassword123!

### ============================================================
### ШАГ 1: ЛОГИН SUPERADMIN
### ============================================================
# @name loginSuperAdmin
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "{{initialAdminEmail}}",
  "password": "{{initialAdminPassword}}"
}

###
@superAdminToken = {{loginSuperAdmin.response.body.$.token}}
@superAdminId = {{loginSuperAdmin.response.body.$.id}}

### ============================================================
### ШАГ 2: РЕГИСТРАЦИЯ ТЕСТОВОГО ПОЛЬЗОВАТЕЛЯ
### ============================================================
# @name registerViewer
POST {{base_url}}/api/auth/register
Content-Type: {{contentType}}

{
  "email": "testuser@example.com",
  "password": "Password123!",
  "userName": "TestUser"
}

###
@testUserId = {{registerViewer.response.body.$.id}}

### ============================================================
### ШАГ 3: ПРОВЕРКА ПОЛУЧЕНИЯ СПИСКА (С ФИЛЬТРАЦИЕЙ)
### ============================================================
GET {{base_url}}/api/admin/users?filter={"q":"testuser"}&sort=["email","ASC"]&range=[0,9]
Authorization: Bearer {{superAdminToken}}

### ============================================================
### ШАГ 4: ОБНОВЛЕНИЕ РОЛИ (НОВЫЙ ФОРМАТ)
### ============================================================
# Теперь используем PUT на корень пользователя и передаем объект
PUT {{base_url}}/api/admin/users/{{testUserId}}
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

{
  "email": "testuser@example.com",
  "userName": "TestUserUpdated",
  "role": "Admin" 
}

### ============================================================
### ШАГ 5: ПРОВЕРКА ИЕРАРХИИ (ОЖИДАЕТСЯ 403)
### ============================================================
# Сначала логинимся под новым Админом
# @name loginAdmin
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "testuser@example.com",
  "password": "Password123!"
}

###
@adminToken = {{loginAdmin.response.body.$.token}}

### ТЕСТ: Админ пытается понизить Супер-Админа (403 Forbidden)
PUT {{base_url}}/api/admin/users/{{superAdminId}}
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}

{
  "email": "{{initialAdminEmail}}",
  "userName": "Admin",
  "role": "Viewer"
}

### ============================================================
### ШАГ 6: УДАЛЕНИЕ ПОЛЬЗОВАТЕЛЯ
### ============================================================
DELETE {{base_url}}/api/admin/users/{{testUserId}}
Authorization: Bearer {{superAdminToken}}