@base_url = http://localhost:5046
@contentType = application/json

### 1. СОЗДАНИЕ ПРОВИНЦИИ (Основа)
# @name createProvince
POST {{base_url}}/api/provinces
Content-Type: {{contentType}}

{
  "name": "San José",
  "slug": "san-jose"
}

###
@provinceId = {{createProvince.response.body.$.id}}

### 2. СОЗДАНИЕ ГОРОДА (Связь с провинцией)
# @name createCity
POST {{base_url}}/api/cities
Content-Type: {{contentType}}

{
  "name": "Escazú",
  "slug": "escazu",
  "provinceId": "{{provinceId}}"
}

###
@cityId = {{createCity.response.body.$.id}}

### 3. СОЗДАНИЕ КАТЕГОРИИ GOOGLE
# @name createCategory
POST {{base_url}}/api/google-categories
Content-Type: {{contentType}}

{
  "gcid": "restaurant",
  "nameEn": "Restaurant",
  "nameEs": "Restaurante"
}

###
@categoryId = {{createCategory.response.body.$.id}}

### 4. СОЗДАНИЕ ТЕГА (Группа + Тег)
# @name createTagGroup
POST {{base_url}}/api/tag-groups
Content-Type: {{contentType}}

{
  "nameEn": "Amenities",
  "nameEs": "Comodidades",
  "slug": "amenities"
}

###
@tagGroupId = {{createTagGroup.response.body.$.id}}

# @name createTag
POST {{base_url}}/api/tags
Content-Type: {{contentType}}

{
  "nameEn": "Free WiFi",
  "nameEs": "WiFi gratis",
  "slug": "free-wifi",
  "tagGroupId": "{{tagGroupId}}"
}

###
@tagId = {{createTag.response.body.$.id}}

############################################################
### ЭТАП 2: СОЗДАНИЕ И ПРОВЕРКА БИЗНЕС-СТРАНИЦЫ
############################################################

### 5. СОЗДАНИЕ БИЗНЕС-СТРАНИЦЫ (Тестируем маппинг и PostGIS)
# @name createBusiness
POST {{base_url}}/api/admin/business-pages
Content-Type: {{contentType}}

{
  "name": "Gourmet Garden Escazu",
  "slug": "gourmet-garden",
  "isPublished": true,
  "languageCode": "en",
  "description": "Best organic food in San Jose",
  "provinceId": "{{provinceId}}",
  "cityId": "{{cityId}}",
  "primaryCategoryId": "{{categoryId}}",
  "secondaryCategoryIds": [],
  "location": {
    "latitude": 9.9304,
    "longitude": -84.1484
  },
  "contacts": {
    "phone": "+506 8888-8888",
    "email": "info@gourmetgarden.cr",
    "website": "https://gourmetgarden.cr",
    "instagram": "gourmetgarden_cr"
  },
  "schedule": [
    {
      "dayOfWeek": 1,
      "intervals": [{ "start": "09:00", "end": "18:00" }]
    }
  ],
  "seo": {
    "title": "Gourmet Garden | Organic Restaurant in Escazu",
    "description": "Visit us for the best organic experience",
    "keywords": "organic, food, escazu",
    "hreflangs": [{ "code": "es", "url": "https://gourmetgarden.cr/es" }]
  },
  "tagIds": ["{{tagId}}"],
  "mediaIds": []
}

###
@businessId = {{createBusiness.response.body.$.id}}

### 6. ПРОВЕРКА DIRTY CHECK (Изменение слага)
# Мы меняем слаг. Система должна сохранить старый в историю (OldSlugs)
PUT {{base_url}}/api/admin/business-pages/{{businessId}}
Content-Type: {{contentType}}

{
  "name": "Gourmet Garden Updated",
  "slug": "gourmet-garden-new",
  "isPublished": true,
  "languageCode": "en",
  "provinceId": "{{provinceId}}",
  "location": { "latitude": 9.9304, "longitude": -84.1484 },
  "contacts": {},
  "schedule": [],
  "seo": { "title": "Updated", "description": "Updated", "keywords": "", "hreflangs": [] },
  "tagIds": [],
  "mediaIds": []
}

### 7. ФИНАЛЬНАЯ ПРОВЕРКА (Смотрим результат)
# Проверьте в ответе:
# 1. Поле "slug" теперь "gourmet-garden-new"
# 2. Поле "oldSlugs" (в БД) должно содержать "gourmet-garden"
GET {{base_url}}/api/admin/business-pages/{{businessId}}