@base_url = http://localhost:5046
@contentType = application/json

# Генерируем уникальную метку для предотвращения конфликтов слагов
@time = {{$timestamp}}

### ==========================================
### 1. АВТОРИЗАЦИЯ
### ==========================================

# @name loginAdmin
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "password": "ComplexPassword123!"
}

### Извлекаем токен
@token = {{loginAdmin.response.body.$.token}}

### ==========================================
### 2. СОЗДАНИЕ ГРУПП ТЕГОВ (CREATE)
### ==========================================

### Создание Группы А (с ней будем тестировать удаление)
# @name createGroupA
POST {{base_url}}/api/tag-groups
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nameEn": "Amenities {{time}}",
  "nameEs": "Comodidades {{time}}",
  "slug": "amenities-{{time}}"
}

###
@groupIdA = {{createGroupA.response.body.$.id}}

### Создание Группы B (с ней будем тестировать обновление)
# @name createGroupB
POST {{base_url}}/api/tag-groups
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nameEn": "Cuisine {{time}}",
  "nameEs": "Cocina {{time}}",
  "slug": "cuisine-{{time}}"
}

###
@groupIdB = {{createGroupB.response.body.$.id}}


### ==========================================
### 3. СОЗДАНИЕ ТЕГОВ (ДЛЯ ПРОВЕРКИ SAFE DELETE)
### ==========================================

### Создаем Тег 1 в Группе А
# @name createTag1
POST {{base_url}}/api/tags
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nameEn": "WiFi {{time}}",
  "nameEs": "WiFi {{time}}",
  "slug": "wifi-{{time}}",
  "tagGroupId": "{{groupIdA}}"
}

###
@tag1Id = {{createTag1.response.body.$.id}}

### Создаем Тег 2 в Группе А
# @name createTag2
POST {{base_url}}/api/tags
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nameEn": "Pool {{time}}",
  "nameEs": "Piscina {{time}}",
  "slug": "pool-{{time}}",
  "tagGroupId": "{{groupIdA}}"
}

###
@tag2Id = {{createTag2.response.body.$.id}}


### ==========================================
### 4. ПОЛУЧЕНИЕ ДАННЫХ (READ / LIST)
### ==========================================

### Получение списка (Имитация стартовой загрузки React Admin: без фильтра)
GET {{base_url}}/api/tag-groups?range=[0,9]&sort=["nameEn","ASC"]&filter={}
Authorization: Bearer {{token}}

### Получение списка (Имитация поиска: ищем статичное слово "Amenities")
GET {{base_url}}/api/tag-groups?range=[0,9]&sort=["nameEn","ASC"]&filter={"q":"Amenities"}
Authorization: Bearer {{token}}

### Получение одной группы по ID
GET {{base_url}}/api/tag-groups/{{groupIdA}}
Authorization: Bearer {{token}}


### ==========================================
### 5. ОБНОВЛЕНИЕ ДАННЫХ (UPDATE)
### ==========================================

### Обновление Группы B
PUT {{base_url}}/api/tag-groups/{{groupIdB}}
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nameEn": "Cuisine Updated {{time}}",
  "nameEs": "Cocina Actualizada {{time}}",
  "slug": "cuisine-updated-{{time}}"
}


### ==========================================
### 6. УДАЛЕНИЕ И ПРОВЕРКА SAFE DELETE (DELETE)
### ==========================================

### ТЕСТ 1: Ожидается 409 Conflict
# Пытаемся удалить Группу А (в ней лежат 2 тега)
DELETE {{base_url}}/api/tag-groups/{{groupIdA}}
Authorization: Bearer {{token}}

### ОЧИСТКА: Удаляем теги из Группы А
DELETE {{base_url}}/api/tags/{{tag1Id}}
Authorization: Bearer {{token}}

###
DELETE {{base_url}}/api/tags/{{tag2Id}}
Authorization: Bearer {{token}}

### ТЕСТ 2: Ожидается 204 No Content
# Теперь Группа А пустая. Удаление должно пройти успешно.
DELETE {{base_url}}/api/tag-groups/{{groupIdA}}
Authorization: Bearer {{token}}

### Удаляем Группу B (Очистка мусора)
DELETE {{base_url}}/api/tag-groups/{{groupIdB}}
Authorization: Bearer {{token}}