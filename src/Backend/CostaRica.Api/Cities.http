@base_url = http://localhost:5046
@contentType = application/json

### ============================================================
### ПОДГОТОВКА ПЕРЕМЕННЫХ И ТОКЕНОВ
### ============================================================

# 1. Логин SuperAdmin
# @name loginSuperAdmin
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "password": "ComplexPassword123!"
}

###
@superAdminToken = {{loginSuperAdmin.response.body.$.token}}

# 2. Создание Провинции (необходима для создания городов)
# @name createProv
POST {{base_url}}/api/provinces
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

{ "name": "Guanacaste", "slug": "guanacaste" }

###
@provinceId = {{createProv.response.body.$.id}}

# 3. Регистрация и логин Менеджера
# @name regManager
POST {{base_url}}/api/auth/register
Content-Type: {{contentType}}

{ "email": "manager-cities@example.com", "password": "Password123!", "userName": "CityManager" }

###
@managerId = {{regManager.response.body.$.id}}

# Повышаем до менеджера
PUT {{base_url}}/api/admin/users/{{managerId}}/roles
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

[ "Manager" ]

###
# @name loginManager
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{ "email": "manager-cities@example.com", "password": "Password123!" }

###
@managerToken = {{loginManager.response.body.$.token}}

# 4. Регистрация Зрителя (Viewer)
# @name regViewer
POST {{base_url}}/api/auth/register
Content-Type: {{contentType}}

{ "email": "viewer-cities@example.com", "password": "Password123!", "userName": "CityViewer" }

###
@viewerToken = {{regViewer.response.body.$.token}}


############################################################
### СЦЕНАРИЙ 1: MANAGER (СОЗДАНИЕ/ЧТЕНИЕ - ДА, УДАЛЕНИЕ - НЕТ)
############################################################

### 1.1 Создание города Менеджером (Должно быть успешно)
# @name createCityManager
POST {{base_url}}/api/cities
Authorization: Bearer {{managerToken}}
Content-Type: {{contentType}}

{
  "name": "Liberia",
  "slug": "liberia",
  "provinceId": "{{provinceId}}"
}

###
@cityId = {{createCityManager.response.body.$.id}}

### 1.2 Получение списка Менеджером (Должно быть успешно)
GET {{base_url}}/api/cities
Authorization: Bearer {{managerToken}}

### 1.3 Попытка удаления Менеджером (Ожидается: 403 Forbidden)
DELETE {{base_url}}/api/cities/{{cityId}}
Authorization: Bearer {{managerToken}}


############################################################
### СЦЕНАРИЙ 2: VIEWER / АНОНИМ (ПОЛНЫЙ БЛОК)
############################################################

### 2.1 Чтение списка Зрителем (Ожидается: 403 Forbidden)
GET {{base_url}}/api/cities
Authorization: Bearer {{viewerToken}}

### 2.2 Чтение списка Анонимом (Ожидается: 401 Unauthorized)
GET {{base_url}}/api/cities


############################################################
### СЦЕНАРИЙ 3: SUPER ADMIN (ЗАВЕРШЕНИЕ ЦИКЛА)
############################################################

### 3.1 Удаление города Админом (Ожидается: 204 No Content)
DELETE {{base_url}}/api/cities/{{cityId}}
Authorization: Bearer {{superAdminToken}}