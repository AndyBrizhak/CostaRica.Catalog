@base_url = http://localhost:5046
@contentType = application/json

### ============================================================
### ПОДГОТОВКА ПЕРЕМЕННЫХ
### ============================================================

# 1. Логин SuperAdmin
# @name loginSuperAdmin
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "password": "ComplexPassword123!"
}

###
@superAdminToken = {{loginSuperAdmin.response.body.$.token}}

# 2. Создание Провинции для тестов
# @name createProv
POST {{base_url}}/api/provinces
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

{ "name": "Guanacaste", "slug": "guanacaste" }

###
@provinceId = {{createProv.response.body.$.id}}

############################################################
### СЦЕНАРИЙ 1: УПРАВЛЕНИЕ ГОРОДАМИ (CRUD)
############################################################

### 1.1 Создание города
# @name createCity
POST {{base_url}}/api/cities
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

{
  "name": "Liberia",
  "slug": "liberia",
  "provinceId": "{{provinceId}}"
}

###
@cityId = {{createCity.response.body.$.id}}

### 1.2 Получение списка (Стандартный запрос React Admin)
# Проверяем пагинацию, сортировку и фильтр одновременно
GET {{base_url}}/api/cities?sort=["name","ASC"]&range=[0,9]&filter={"provinceId":"{{provinceId}}"}
Authorization: Bearer {{superAdminToken}}

### 1.3 Глобальный поиск (Параметр Q)
# Проверяем, как работает наш новый парсинг JSON-фильтра
GET {{base_url}}/api/cities?filter={"q":"Lib"}
Authorization: Bearer {{superAdminToken}}

### 1.4 Обновление города (PUT)
# Теперь мы ожидаем 200 OK и объект города в ответе
PUT {{base_url}}/api/cities/{{cityId}}
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

{
  "name": "Liberia Central",
  "slug": "liberia-central",
  "provinceId": "{{provinceId}}"
}

### 1.5 Удаление города
DELETE {{base_url}}/api/cities/{{cityId}}
Authorization: Bearer {{superAdminToken}}


############################################################
### СЦЕНАРИЙ 2: ПРОВЕРКА ОШИБОК И ВАЛИДАЦИИ
############################################################

### 2.1 Ошибка: Дубликат Слага (Ожидается 400 Bad Request)
POST {{base_url}}/api/cities
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

{
  "name": "Another Liberia",
  "slug": "liberia", 
  "provinceId": "{{provinceId}}"
}

### 2.2 Ошибка: Несуществующая провинция
POST {{base_url}}/api/cities
Authorization: Bearer {{superAdminToken}}
Content-Type: {{contentType}}

{
  "name": "Ghost City",
  "slug": "ghost-city",
  "provinceId": "00000000-0000-0000-0000-000000000000"
}