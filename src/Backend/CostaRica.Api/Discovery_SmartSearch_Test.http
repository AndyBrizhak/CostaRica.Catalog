@base_url = http://localhost:5046
@contentType = application/json

############################################################
### ЭТАП 1: АВТОРИЗАЦИЯ (SUPER ADMIN)
############################################################

# @name loginAdmin
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "password": "ComplexPassword123!"
}

###
@adminToken = {{loginAdmin.response.body.$.token}}


############################################################
### ЭТАП 2: ГЕОГРАФИЯ (ПРОВИНЦИИ И ГОРОДА)
############################################################

# 2.1 Провинции
# @name createProvSJ
POST {{base_url}}/api/provinces
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "name": "San José", "slug": "san-jose" }

###
# @name createProvAL
POST {{base_url}}/api/provinces
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "name": "Alajuela", "slug": "alajuela" }

###
@idSJ = {{createProvSJ.response.body.$.id}}
@idAL = {{createProvAL.response.body.$.id}}


# 2.2 Города
# @name createCityEscazu
POST {{base_url}}/api/cities
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "name": "Escazú", "slug": "escazu", "provinceId": "{{idSJ}}" }

###
# @name createCitySantaAna
POST {{base_url}}/api/cities
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "name": "Santa Ana", "slug": "santa-ana", "provinceId": "{{idSJ}}" }

###
# @name createCityFortuna
POST {{base_url}}/api/cities
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "name": "La Fortuna", "slug": "la-fortuna", "provinceId": "{{idAL}}" }

###
@idEscazu = {{createCityEscazu.response.body.$.id}}
@idSantaAna = {{createCitySantaAna.response.body.$.id}}
@idFortuna = {{createCityFortuna.response.body.$.id}}


############################################################
### ЭТАП 3: ТЕГИ И КАТЕГОРИИ
############################################################

# 3.1 Группы тегов
# @name createGroupAmenities
POST {{base_url}}/api/tag-groups
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "nameEn": "Amenities", "nameEs": "Comodidades", "slug": "amenities" }

###
# @name createGroupCuisine
POST {{base_url}}/api/tag-groups
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "nameEn": "Cuisine", "nameEs": "Cocina", "slug": "cuisine" }

###
@idGrpAmen = {{createGroupAmenities.response.body.$.id}}
@idGrpCuisine = {{createGroupCuisine.response.body.$.id}}


# 3.2 Теги
# @name tagWiFi
POST {{base_url}}/api/tags
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "nameEn": "WiFi", "nameEs": "WiFi", "slug": "wifi", "tagGroupId": "{{idGrpAmen}}" }

###
# @name tagParking
POST {{base_url}}/api/tags
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "nameEn": "Parking", "nameEs": "Parqueo", "slug": "parking", "tagGroupId": "{{idGrpAmen}}" }

###
# @name tagPizza
POST {{base_url}}/api/tags
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "nameEn": "Pizza", "nameEs": "Pizza", "slug": "pizza", "tagGroupId": "{{idGrpCuisine}}" }

###
@idWiFi = {{tagWiFi.response.body.$.id}}
@idParking = {{tagParking.response.body.$.id}}
@idPizza = {{tagPizza.response.body.$.id}}


# 3.3 Категория
# @name createCategory
POST {{base_url}}/api/google-categories
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{ "gcid": "restaurant", "nameEn": "Restaurant", "nameEs": "Restaurante" }

###
@idCat = {{createCategory.response.body.$.id}}


############################################################
### ЭТАП 4: БИЗНЕС-СТРАНИЦЫ (6 ОБЪЕКТОВ ДЛЯ ТЕСТОВ)
############################################################

# 4.1 Escazu: Pizza + WiFi (~6.5 км от центра SJ)
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{
  "name": "Escazu Pizza Hut", "slug": "escazu-pizza", "isPublished": true,
  "provinceId": "{{idSJ}}", "cityId": "{{idEscazu}}", "primaryCategoryId": "{{idCat}}",
  "tagIds": ["{{idPizza}}", "{{idWiFi}}"],
  "location": { "latitude": 9.9200, "longitude": -84.1400 }
}

###
# 4.2 Escazu: Only Parking (~7 км от центра SJ)
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{
  "name": "Escazu Parking Central", "slug": "escazu-parking", "isPublished": true,
  "provinceId": "{{idSJ}}", "cityId": "{{idEscazu}}", "primaryCategoryId": "{{idCat}}",
  "tagIds": ["{{idParking}}"],
  "location": { "latitude": 9.9250, "longitude": -84.1450 }
}

###
# 4.3 Santa Ana: WiFi + Parking (~11 км от центра SJ)
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{
  "name": "Santa Ana Work Space", "slug": "santa-ana-work", "isPublished": true,
  "provinceId": "{{idSJ}}", "cityId": "{{idSantaAna}}", "primaryCategoryId": "{{idCat}}",
  "tagIds": ["{{idWiFi}}", "{{idParking}}"],
  "location": { "latitude": 9.9320, "longitude": -84.1800 }
}

###
# 4.4 Santa Ana: Only Pizza (~10.5 км от центра SJ)
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{
  "name": "Santa Ana Pizza Place", "slug": "santa-ana-pizza", "isPublished": true,
  "provinceId": "{{idSJ}}", "cityId": "{{idSantaAna}}", "primaryCategoryId": "{{idCat}}",
  "tagIds": ["{{idPizza}}"],
  "location": { "latitude": 9.9350, "longitude": -84.1750 }
}

###
# 4.5 Fortuna: Pizza + WiFi (~100 км от центра SJ)
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{
  "name": "Fortuna Lake Food", "slug": "fortuna-pizza", "isPublished": true,
  "provinceId": "{{idAL}}", "cityId": "{{idFortuna}}", "primaryCategoryId": "{{idCat}}",
  "tagIds": ["{{idPizza}}", "{{idWiFi}}"],
  "location": { "latitude": 10.4700, "longitude": -84.6400 }
}

###
# 4.6 Fortuna: Only WiFi
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}
{
  "name": "Fortuna Coffee", "slug": "fortuna-coffee", "isPublished": true,
  "provinceId": "{{idAL}}", "cityId": "{{idFortuna}}", "primaryCategoryId": "{{idCat}}",
  "tagIds": ["{{idWiFi}}"],
  "location": { "latitude": 10.4710, "longitude": -84.6410 }
}


############################################################
### ЭТАП 5: ГЕО-ПОИСК И РАНЖИРОВАНИЕ (ПУБЛИЧНО)
############################################################

### 5.1 Поиск в радиусе 50км от центра SJ (9.9333, -84.0833)
# Ожидается список из 4 заведений (SJ), отсортированных по дистанции.
GET {{base_url}}/api/discovery/search?lat=9.9333&lon=-84.0833&radiusInKm=50

### 5.2 Доступные Провинции (радиус 15км)
# Ожидается: Только San José.
GET {{base_url}}/api/discovery/provinces?lat=9.9333&lon=-84.0833&radiusInKm=15

### 5.3 Доступные Города (радиус 8км)
# Ожидается: Только Escazú.
GET {{base_url}}/api/discovery/cities?lat=9.9333&lon=-84.0833&radiusInKm=8

### 5.4 Доступные Теги (радиус 12км)
# Ожидается: Pizza, WiFi, Parking.
GET {{base_url}}/api/discovery/tags?lat=9.9333&lon=-84.0833&radiusInKm=12


############################################################
### ЭТАП 6: УМНЫЙ ПОИСК (FACETED / DRILL-DOWN) БЕЗ ГЕО
############################################################

### 6.1 Выбор Провинции (SJ) -> Результаты
# Ожидаемые города: Escazu, Santa Ana. Ожидаемые страницы: 4 объекта.
GET {{base_url}}/api/discovery/search?provinceId={{idSJ}}

### 6.2 Выбор Провинции (SJ) -> Какие города доступны?
GET {{base_url}}/api/discovery/cities?provinceId={{idSJ}}

### 6.3 Выбор Провинции (SJ) + Города (Santa Ana) -> Какие теги доступны?
# Ожидается: Pizza, WiFi, Parking (те теги, что есть у Santa Ana).
GET {{base_url}}/api/discovery/tags?provinceId={{idSJ}}&cityId={{idSantaAna}}

### 6.4 Выбор Провинции (SJ) + Города (Santa Ana) + Тега (Pizza) -> Страницы
# Ожидается: 1 страница (Santa Ana Pizza Place).
GET {{base_url}}/api/discovery/search?provinceId={{idSJ}}&cityId={{idSantaAna}}&tagIds={{idPizza}}

### 6.5 Проверка "оставшихся тегов" для 6.4
# Какие теги еще можно выбрать в Santa Ana, если уже выбрана Pizza? 
# Т.к. у "Santa Ana Pizza Place" других тегов нет, список может быть пуст или ограничен.
GET {{base_url}}/api/discovery/tags?provinceId={{idSJ}}&cityId={{idSantaAna}}&tagIds={{idPizza}}

### 6.6 Выбор Тега (WiFi) -> Доступные Провинции
# Должны вернуться обе: SJ и Alajuela.
GET {{base_url}}/api/discovery/provinces?tagIds={{idWiFi}}