@base_url = http://localhost:5046
@contentType = application/json
@prefix = DSC-{{$timestamp}}

### ============================================================
### 1. АВТОРИЗАЦИЯ
### ============================================================

# @name login
POST {{base_url}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@example.com",
  "password": "ComplexPassword123!"
}

###
@token = {{login.response.body.$.token}}


### ============================================================
### 2. ПОДГОТОВКА ИНФРАСТРУКТУРЫ (СПРАВОЧНИКИ)
### ============================================================

### 2.1 Провинция 1 (San José)
# @name createProvSJ
POST {{base_url}}/api/provinces
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{ "name": "{{prefix}}-SanJose", "slug": "sj-{{$guid}}" }

###
@provSJ = {{createProvSJ.response.body.$.id}}

### 2.2 Провинция 2 (Alajuela)
# @name createProvAL
POST {{base_url}}/api/provinces
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{ "name": "{{prefix}}-Alajuela", "slug": "al-{{$guid}}" }

###
@provAL = {{createProvAL.response.body.$.id}}

### 2.3 Город в San José (Escazú)
# @name createCityEscazu
POST {{base_url}}/api/cities
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{ "name": "Escazu-{{prefix}}", "slug": "escazu-{{$guid}}", "provinceId": "{{provSJ}}" }

###
@cityEscazu = {{createCityEscazu.response.body.$.id}}

### 2.4 Город в Alajuela (Alajuela Center)
# @name createCityAlajuela
POST {{base_url}}/api/cities
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{ "name": "Alajuela-{{prefix}}", "slug": "alajuela-{{$guid}}", "provinceId": "{{provAL}}" }

###
@cityAlajuela = {{createCityAlajuela.response.body.$.id}}

### 2.5 Категории (Food vs Hotel)
# @name createCatFood
POST {{base_url}}/api/google-categories
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{ "gcid": "food_{{$guid}}", "nameEn": "Food-{{prefix}}", "nameEs": "Comida" }

###
@catFood = {{createCatFood.response.body.$.id}}

# @name createCatHotel
POST {{base_url}}/api/google-categories
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{ "gcid": "hotel_{{$guid}}", "nameEn": "Hotel-{{prefix}}", "nameEs": "Hotel" }

###
@catHotel = {{createCatHotel.response.body.$.id}}


### ============================================================
### 3. СОЗДАНИЕ БИЗНЕС-СТРАНИЦ (РАЗНЫЕ ЛОКАЦИИ)
### ============================================================

### 3.1 Бизнес №1: Ресторан в Сан-Хосе (Escazu)
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "name": "Pizza Palace {{prefix}}",
  "slug": "pizza-{{$guid}}",
  "isPublished": true,
  "languageCode": "en",
  "provinceId": "{{provSJ}}",
  "cityId": "{{cityEscazu}}",
  "primaryCategoryId": "{{catFood}}",
  "location": { "latitude": 9.9320, "longitude": -84.1450 },
  "contacts": { "phone": "111" }, "seo": { "title": "Pizza" }, "schedule": []
}

### 3.2 Бизнес №2: Отель в Сан-Хосе (Escazu) - Рядом с пиццерией
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "name": "Luxury Hotel {{prefix}}",
  "slug": "hotel-sj-{{$guid}}",
  "isPublished": true,
  "languageCode": "en",
  "provinceId": "{{provSJ}}",
  "cityId": "{{cityEscazu}}",
  "primaryCategoryId": "{{catHotel}}",
  "location": { "latitude": 9.9350, "longitude": -84.1480 },
  "contacts": { "phone": "222" }, "seo": { "title": "Hotel SJ" }, "schedule": []
}

### 3.3 Бизнес №3: Отель в Алахуэле (~15-20км от Сан-Хосе)
POST {{base_url}}/api/admin/business-pages
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "name": "Airport Stay {{prefix}}",
  "slug": "hotel-al-{{$guid}}",
  "isPublished": true,
  "languageCode": "en",
  "provinceId": "{{provAL}}",
  "cityId": "{{cityAlajuela}}",
  "primaryCategoryId": "{{catHotel}}",
  "location": { "latitude": 10.0020, "longitude": -84.2120 },
  "contacts": { "phone": "333" }, "seo": { "title": "Hotel AL" }, "schedule": []
}


### ============================================================
### 4. ТЕСТИРОВАНИЕ DISCOVERY (ПУБЛИЧНЫЙ ПОИСК)
### ============================================================

### 4.1 Поиск по Провинции (Должен вернуть 2 объекта из SJ)
GET {{base_url}}/api/discovery/search?provinceId={{provSJ}}&page=1&pageSize=10

### 4.2 Поиск по Городу (Должен вернуть 1 объект из Alajuela)
GET {{base_url}}/api/discovery/search?cityId={{cityAlajuela}}

### 4.3 Поиск по Категории (Должен вернуть 2 Отеля по всей стране)
GET {{base_url}}/api/discovery/search?categoryId={{catHotel}}

### 4.4 Поиск по Категории + Провинции (Только Отель в Сан-Хосе)
GET {{base_url}}/api/discovery/search?categoryId={{catHotel}}&provinceId={{provSJ}}


### ============================================================
### 5. ТЕСТИРОВАНИЕ ГЕО-ЛОКАЦИИ (ДИСТАНЦИЯ)
### ============================================================

### 5.1 Точка в Escazu, радиус 2км (Должен найти 2 объекта: Пиццерия и Отель SJ)
GET {{base_url}}/api/discovery/search?lat=9.9333&lon=-84.1460&radiusInKm=2

### 5.2 Точка в Escazu, радиус 20км (Должен найти ВСЕ 3 объекта, включая Алахуэлу)
GET {{base_url}}/api/discovery/search?lat=9.9333&lon=-84.1460&radiusInKm=20

### 5.3 Проверка сортировки по дистанции 
# Объекты в ответе должны идти в порядке: Luxury Hotel (ближайший), Pizza Palace, Airport Stay (дальний)
GET {{base_url}}/api/discovery/search?lat=9.9360&lon=-84.1490